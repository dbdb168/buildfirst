{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/data/**",
              "components/feedback/**",
              "components/navigation/**",
              "components/surfaces/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Arimo|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Arimo, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|onClick|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children, onClick, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: accent, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sub|accent|style|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, sub, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionBand'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|caption|lead|color|style|key|ref|className|style|children)$/]",
        "message": "<SectionBand> doesn't accept that prop. Declared props: title, caption, lead, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpectrumMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:stages|activeIndex|style|key|ref|className|style|children)$/]",
        "message": "<SpectrumMeter> doesn't accept that prop. Declared props: stages, activeIndex, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:critical|warning|ok|amber|neutral)$/]",
        "message": "<Tag> variant must be one of 'critical' | 'warning' | 'ok' | 'amber' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TicketButtons'] > JSXAttribute > JSXIdentifier[name!=/^(?:skipLabel|startLabel|surface|onSkip|onStart|style|key|ref|className|style|children)$/]",
        "message": "<TicketButtons> doesn't accept that prop. Declared props: skipLabel, startLabel, surface, onSkip, onStart, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
      },
      "Card": {
        "replaces": []
      },
      "MetricCard": {
